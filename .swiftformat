# Disable all rules first
--disable all

# Enable specific rules
--enable andOperator
--enable blankLineAfterImports
--enable blankLineAfterSwitchCase
--enable blankLinesAfterGuardStatements
--enable blankLinesAroundMark
--enable blankLinesAtEndOfScope
--enable blankLinesBetweenChainedFunctions
--enable blankLinesBetweenImports
--enable blankLinesAtStartOfScope
--enable blankLinesBetweenScopes
--enable blockComments
--enable conditionalAssignment
--enable consecutiveBlankLines
--enable consecutiveSpaces
--enable consistentSwitchCaseSpacing
--enable duplicateImports
--enable elseOnSameLine
--enable emptyBraces
--enable enumNamespaces
--enable headerFileName
--enable hoistPatternLet
--enable isEmpty
--enable organizeDeclarations
--enable preferForLoop
--enable propertyTypes
--enable redundantBackticks
--enable redundantBreak
--enable redundantClosure
--enable redundantExtensionACL
--enable redundantFileprivate
--enable redundantGet
--enable redundantInit
--enable redundantInternal
--enable redundantLet
--enable redundantLetError
--enable redundantNilInit
--enable redundantOptionalBinding
--enable redundantParens
--enable redundantPattern
--enable redundantProperty
--enable redundantPublic
--enable redundantRawValues
--enable redundantReturn
--enable redundantSelf
--enable redundantStaticSelf
--enable redundantType
--enable redundantThrows
--enable redundantTypedThrows
--enable redundantViewBuilder
--enable redundantVoidReturnType
--enable semicolons
--enable simplifyGenericConstraints
--enable singlePropertyPerLine
--enable sortDeclarations
--enable sortImports
--enable sortSwitchCases
--enable sortTypealiases
--enable spaceAroundBraces
--enable spaceAroundBrackets
--enable spaceAroundComments
--enable spaceAroundGenerics
--enable spaceAroundParens
--enable spaceInsideBraces
--enable spaceInsideGenerics
--enable spaceInsideBrackets
--enable spaceInsideComments
--enable spaceInsideGenerics
--enable spaceInsideParens
--enable strongOutlets
--enable todos
--enable trailingSpace
--enable wrapEnumCases
--enable wrapLoopBodies
--enable typeSugar
--enable unusedArguments
--enable unusedPrivateDeclarations
--enable wrapConditionalBodies
--enable wrapEnumCases
--enable wrapFunctionBodies
--enable wrapLoopBodies
--enable wrapMultilineFunctionChains
--enable wrapPropertyBodies