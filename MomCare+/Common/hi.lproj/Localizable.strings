"terms_law_content" = "ये शर्तें भारत के कानूनों द्वारा शासित हैं। कोई भी विवाद गौतम बुद्ध नगर की अदालतों में हल किया जाएगा।";
"terms_contact_us_title" = "संपर्क करें";
