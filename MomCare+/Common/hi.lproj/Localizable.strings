"privacy_section_works_content" = "• MomCare+ आपको मन की शांति के साथ गर्भावस्था में मदद करता है। हमारी सुविधाओं में शामिल हैं:\n• तिमाही-विशिष्ट मार्गदर्शन साप्ताहिक रूप से प्रदान किया जाता है\n• मूड, आहार, जलयोजन, लक्षण और व्यायाम ट्रैकिंग\n• स्कैन, जाँच, पूरक और स्व-देखभाल के लिए अनुस्मारक\n• मानसिक स्वास्थ्य उपकरण जैसे गाइडेड ब्रीदिंग और मूड\n\nइस अनुभव को प्रदान करने के लिए, हम कुछ ऐसी जानकारी एकत्र करते हैं जो आप साझा करना चाहते हैं। यहाँ बताया गया है कि हम क्या एकत्र करते हैं और क्यों।";
"privacy_section_collect_title" = "हम क्या जानकारी एकत्र करते हैं";
"privacy_section_collect_content" = "• प्रोफ़ाइल और गर्भावस्था जानकारी: आयु, नियत तारीख, गर्भावस्था प्रारंभ तिथि, नाम (वैकल्पिक)\n• स्वास्थ्य डेटा: लक्षण, एलर्जी, पहले से मौजूद स्थितियाँ, चिकित्सा नोट्स\n• दैनिक लॉग: मूड, जलयोजन, भोजन सेवन, ऊर्जा स्तर, व्यायाम ट्रैकिंग\n• अनुस्मारक और नोट्स: अपॉइंटमेंट प्रविष्टियाँ, कैलेंडर ईवेंट, स्कैन तिथियाँ\n\nडिवाइस और डायग्नोस्टिक डेटा:\n• डिवाइस प्रकार, iOS संस्करण\n• ऐप संस्करण और उपयोग विश्लेषण\n• क्रैश लॉग और त्रुटि रिपोर्टिंग (अज्ञात और एकत्रित)";
"privacy_section_why_title" = "हम आपका डेटा क्यों एकत्र करते हैं";
"privacy_section_why_content" = "• आपके गर्भावस्था चरण के आधार पर साप्ताहिक अपडेट उत्पन्न करना\n• आहार/व्यायाम प्रगति ट्रैक करना और स्वास्थ्य रुझान दिखाना\n• जलयोजन, पूरक, या चिकित्सा जाँच के लिए कस्टम अनुस्मारक भेजना\n• शांत संगीत, व्यायाम और माइंडफुलनेस उपकरण सुझाना\n• स्ट्रीक और पुरस्कारों के माध्यम से प्रेरणा बढ़ाना\n• ऐप प्रदर्शन में सुधार करना और बग को कम करना\n\nहम आपका डेटा किसी भी तरह से बेचते, किराए पर देते या मुद्रीकृत नहीं करते। कभी नहीं।";
"privacy_section_protect_title" = "हम आपका डेटा कैसे सुरक्षित करते हैं";
"privacy_section_protect_content" = "• संवेदनशील स्वास्थ्य और मूड डेटा का ऑन-डिवाइस एन्क्रिप्शन\n• GDPR-अनुपालक प्लेटफ़ॉर्म के माध्यम से एन्क्रिप्टेड क्लाउड स्टोरेज\n• टोकन-आधारित प्रमाणीकरण और सुरक्षित API\n• पहुँच नियंत्रण जो आंतरिक रूप से भी आपका डेटा देखने वाले लोगों को सीमित करते हैं\n\nआप हमेशा अपने डेटा के पूर्ण स्वामी रहते हैं।";
"privacy_section_rights_title" = "आपके गोपनीयता अधिकार";
"privacy_section_rights_content" = "• पहुँच का अधिकार – देखें कि हमने आपके बारे में क्या डेटा एकत्र किया है\n• सुधार का अधिकार – गलत या पुरानी प्रोफ़ाइल जानकारी अपडेट करें\n• हटाने का अधिकार – अपना पूरा खाता और संबंधित डेटा हटाने का अनुरोध करें\n• सहमति वापस लेने का अधिकार – कभी भी ट्रैकिंग, सूचनाएं, या क्लाउड सिंक अक्षम करें\n• निर्यात का अधिकार – अनुरोध पर GDPR-अनुपालक डेटा निर्यात उपलब्ध है";

// About Us
"about_story" = "गर्भावस्था ऐप्स की दुनिया शोरगुल भरी, अव्यवस्थित और भारी हो सकती है। हम जानते हैं, क्योंकि हम खुद वहाँ से गुजरे हैं।\n\nहमारी यात्रा तब शुरू हुई जब हमने एक प्रियजन को मीलों दूर से अपनी गर्भावस्था में नेविगेट करते देखा, जो उस भरोसेमंद समर्थन के लिए रोज़ाना घर फोन करती थी जो उसे ऑनलाइन नहीं मिल रहा था। इसने हमें — आर्यन, खुशी, ऋतिक और नुपुर को — एक साधारण सवाल पूछने के लिए प्रेरित किया: **क्या होगा अगर कोई ऐप एक शांत साथी की तरह महसूस कर सके, न कि एक बाज़ार की तरह?**\n\nहमने शोध में गहराई से उतरे और पाया कि अधिकांश ऐप्स उत्पाद बेचने पर केंद्रित थे, जबकि यात्रा के केंद्र में वास्तविक व्यक्ति — माँ — को अक्सर नज़रअंदाज़ किया गया था। हम जानते थे कि हमें एक बेहतर विकल्प बनाना होगा।\n\nMomCare+ हमारा उत्तर है।\n\nइसे शुरू से शांति, स्पष्टता और वास्तविक देखभाल प्रदान करने के लिए डिज़ाइन किया गया था।\n\n• अव्यवस्था के बजाय, हम फोकस प्रदान करते हैं। आपको केवल वही मिलेगा जो आपको वास्तव में चाहिए: व्यक्तिगत भोजन और व्यायाम योजनाएं, एक सहज लक्षण ट्रैकर, और आपके मन की शांति को सहारा देने के लिए शांत ऑडियो।\n• बिक्री की बात के बजाय, हम समर्थन प्रदान करते हैं। हमारा लक्ष्य आपको चीज़ें बेचना नहीं है; यह आपको साक्ष्य-आधारित उपकरणों से सशक्त बनाना है जो आपके स्वास्थ्य और कल्याण को प्राथमिकता देते हैं।\n• शिशु-केंद्रित होने के बजाय, हम माँ-केंद्रित हैं। हमारा मानना है कि एक स्वस्थ, समर्थित और सम्मानित माँ हर चीज़ की नींव है।\n\nMomCare+ की हर सुविधा एक एकल अवलोकन, एक टीम चर्चा, और हर उम्मीद करने वाली माँ के लिए वह ऐप बनाने की साझा मिशन से आती है जो हम चाहते थे कि मौजूद हो। शांति में आपका स्वागत है।";
"about_mission" = "अपेक्षित माताओं को उनकी प्रसवपूर्व यात्रा के लिए एक एकल, शांत और व्यापक उपकरण के साथ सशक्त बनाना, हर कदम पर उनकी भलाई पर ध्यान केंद्रित करना।";
"about_quote" = "हर गर्भावस्था की अपनी कहानी है, अपनी लय है, अपनी जरूरतें हैं। हमारा मिशन वह व्यक्तिगत, अटूट समर्थन प्रदान करना है जो आपकी गर्भावस्था को सम्मान देता है।";

