// Disclaimers
"disclaimer_header_title" = "MomCare आपका समर्थन करता है, लेकिन आपका डॉक्टर आपको सबसे अच्छी तरह जानता है!";
"disclaimer_header_subtitle" = "आपकी सुरक्षा और समझ हमारे लिए महत्वपूर्ण है। MomCare+ का उपयोग करने से पहले कृपया नीचे दी गई जानकारी की समीक्षा करें।";
"disclaimer_footer" = "MomCare+ का उपयोग करके, आप स्वीकार करते हैं कि आपने इन अस्वीकरणों को पढ़ और समझ लिया है।";
"disclaimer_medical_title" = "1. सामान्य चिकित्सा अस्वीकरण";
"disclaimer_medical_content" = "यह ऐप्लिकेशन पेशेवर चिकित्सा सलाह, निदान, या उपचार का विकल्प नहीं है।\nMomCare+ में प्रदान की गई सामग्री केवल सूचनात्मक और शैक्षिक उद्देश्यों के लिए है। यह आपके डॉक्टर, दाई, या अन्य योग्य स्वास्थ्य सेवा प्रदाता से पेशेवर चिकित्सा सलाह का विकल्प नहीं है।\nकिसी भी चिकित्सा स्थिति के बारे में हमेशा अपने चिकित्सक या किसी अन्य योग्य स्वास्थ्य पेशेवर की सलाह लें। इस ऐप्लिकेशन में आपने जो पढ़ा है उसके कारण कभी भी पेशेवर चिकित्सा सलाह को अनदेखा न करें। यदि आपको लगता है कि कोई चिकित्सा आपातस्थिति है, तो तुरंत अपने डॉक्टर या आपातकालीन सेवाओं को कॉल करें।";
"disclaimer_tips_title" = "2. दैनिक सुझाव";
"disclaimer_tips_content" = "अस्वीकरण: डैशबोर्ड पर प्रदान किए गए दैनिक सुझाव सामान्य मार्गदर्शन और सूचनात्मक उद्देश्यों के लिए हैं। हम सटीक और उपयोगी जानकारी प्रदान करने का प्रयास करते हैं, लेकिन हम इन सुझावों की सटीकता, वैधता या पूर्णता के संबंध में कोई वारंटी नहीं देते हैं।";
"disclaimer_meals_title" = "3. व्यक्तिगत भोजन योजनाएं";
"disclaimer_meals_content" = "अस्वीकरण: इस ऐप में प्रदान की गई भोजन योजनाएं आपके द्वारा प्रदान की गई स्वास्थ्य स्थितियों, एलर्जी और आहार प्राथमिकताओं के आधार पर व्यक्तिगत हैं।\nहालाँकि, यह स्वचालित योजना किसी पंजीकृत आहार विशेषज्ञ या आपके स्वास्थ्य सेवा प्रदाता के साथ सीधी परामर्श का विकल्प नहीं है। यह सुनिश्चित करना आपकी जिम्मेदारी है कि ऐप में दर्ज की गई सभी जानकारी सटीक और पूर्ण हो। MomCare+ भोजन योजनाओं से उत्पन्न किसी भी प्रतिकूल परिणाम के लिए उत्तरदायी नहीं है।";
"disclaimer_meals_source" = "उद्धरण: पोषण डेटा और भोजन योजना संरचनाएं [Kaggle](https://www.kaggle.com/datasets/sayyamsancheti/indian-state-wise-meals-with-nutritional-values) द्वारा प्रदान किए गए डेटासेट पर आधारित हैं।";
"disclaimer_exercise_title" = "4. व्यायाम और योग योजनाएं";
"disclaimer_exercise_content" = "अस्वीकरण: इस ऐप में व्यायाम और योग वीडियो को गर्भावस्था के उस विशिष्ट सप्ताह के लिए सुरक्षित और उपयुक्त होने के लिए सावधानीपूर्वक चुना गया है।\nहालाँकि, हर गर्भावस्था अनोखी होती है। आपकी व्यक्तिगत स्वास्थ्य स्थिति या विशिष्ट चिकित्सा स्थितियां के लिए संशोधन की आवश्यकता हो सकती है। इस या किसी भी व्यायाम कार्यक्रम को शुरू करने से पहले अपने डॉक्टर से परामर्श करना अनिवार्य है। अपने शरीर की सुनें और दर्द, चक्कर या असुविधा होने पर तुरंत रुकें। इन व्यायामों में भाग लेकर, आप सहमत हैं कि आप ऐसा अपने जोखिम पर कर रहे हैं।";
"disclaimer_exercise_source" = "उद्धरण: योग और व्यायाम वीडियो सामग्री [Pexels.com](https://www.pexels.com/search/videos/pregnancy%20yogas/) के सौजन्य से प्रदान की गई है।";
"disclaimer_baby_growth_title" = "5. शिशु विकास और वृद्धि ट्रैकर";
"disclaimer_baby_growth_content" = "अस्वीकरण: सप्ताह-दर-सप्ताह शिशु आकार तुलनाएं चित्रात्मक अनुमान हैं जो आपके बच्चे की वृद्धि की कल्पना करने का एक मज़ेदार तरीका प्रदान करती हैं। भ्रूण का विकास प्रत्येक गर्भावस्था के लिए अनोखा होता है और विभिन्न कारकों से प्रभावित हो सकता है। इस ऐप में उपयोग किए गए डेटा सामान्य औसत पर आधारित हैं। ये तुलनाएं चिकित्सीय उपकरण नहीं हैं और नैदानिक उद्देश्यों के लिए उपयोग नहीं की जानी चाहिए।";
"disclaimer_articles_title" = "6. गर्भावस्था लेख";
"disclaimer_articles_content" = "अस्वीकरण: आपको विश्वसनीय जानकारी प्रदान करने के लिए, हमने सरकारी स्वास्थ्य संगठनों और प्रमुख चिकित्सा प्रकाशनों से लेखों का सावधानीपूर्वक चयन किया है।\nहालाँकि, MomCare+ इन लेखों के भीतर हर एकल तथ्य की स्वतंत्र रूप से पुष्टि नहीं करता है। यह सामग्री शैक्षिक उद्देश्यों के लिए है और MomCare+ के विचारों को आवश्यक रूप से प्रतिबिंबित नहीं करती। यह जानकारी आपके स्वास्थ्य सेवा प्रदाता से सीधी पेशेवर चिकित्सा सलाह का विकल्प नहीं है।";
"disclaimer_articles_source" = "उद्धरण:\n• [American College of Obstetricians and Gynecologists](https://www.acog.org/womens-health/patient-education)\n• [BabyCenter](https://www.babycenter.com/pregnancy-week-by-week)\n• [What to Expect](https://www.whattoexpect.com/pregnancy/week-by-week/)\n• [WomensHealth.gov](https://www.womenshealth.gov/pregnancy/)";
"disclaimer_mood_title" = "7. मूड ट्रैकिंग और संगीत सुझाव";
"disclaimer_mood_content" = "अस्वीकरण: मूड ट्रैकिंग सुविधा आपकी भावनात्मक भलाई बनाए रखने में मदद करने के लिए डिज़ाइन की गई है। आप जो मूड लॉग करते हैं उसके आधार पर, हमारी प्रणाली संगीत सुझाती है जो सुकून, शांति या उत्साह प्रदान करने के लिए चुना गया है।\nयह समझना महत्वपूर्ण है कि यह केवल आराम और मनोरंजन के लिए है। यह एक नैदानिक उपकरण नहीं है और प्रसवपूर्व या प्रसवोत्तर अवसाद जैसी स्थितियों का पता नहीं लगा सकती। यदि आप लगातार कम मूड या चिंता का अनुभव कर रहे हैं, तो अपने स्वास्थ्य सेवा प्रदाता से बात करना आवश्यक है।";
"disclaimer_mood_source" = "उद्धरण: छवियाँ और धुनें [Free To Use](https://freetouse.com) से ली गई हैं।";

