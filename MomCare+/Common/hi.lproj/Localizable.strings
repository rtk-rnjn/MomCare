// Terms of Service - View strings
"terms_header_title" = "अच्छे नियम एक ऐसा स्थान बनाते हैं जहाँ हर कोई सुरक्षित और सम्मानित महसूस कर सकता है।";
"terms_header_subtitle" = "स्पष्टता विश्वास की नींव है। हमारी शर्तें स्पष्ट होने के लिए डिज़ाइन की गई हैं, ताकि हमारा रिश्ता मज़बूत हो सके।";
"terms_eligibility_title" = "पात्रता – MomCare का उपयोग कौन कर सकता है";
"terms_eligibility_bullet_1" = "आपकी आयु **कम से कम 18 वर्ष** या आपके देश में वयस्कता की कानूनी आयु होनी चाहिए।";
"terms_eligibility_bullet_2" = "आप **गर्भवती** होनी चाहिए, गर्भावस्था की योजना बना रहे हों, या देखभालकर्ता/सहायता व्यक्ति होनी चाहिए।";
"terms_eligibility_bullet_3" = "आपको इन सेवा की शर्तों और हमारी गोपनीयता नीति से **सहमत होना और उनका पालन करना** होगा।";
"terms_eligibility_footer" = "MomCare ऐप **बच्चों द्वारा उपयोग के लिए अभिप्रेत नहीं है**, न ही यह पेशेवर चिकित्सा कर्मियों के लिए रोगी रिकॉर्ड प्रबंधित करने का उपकरण है।";
"terms_overview_title" = "सेवाओं का अवलोकन";
"terms_overview_intro" = "MomCare आपकी गर्भावस्था यात्रा को बेहतर बनाने के लिए डिज़ाइन किए गए उपकरणों की एक श्रृंखला प्रदान करता है:";
"terms_progress_description" = "आपकी दैनिक/साप्ताहिक व्यायाम और आहार प्रगति का एक व्यापक सारांश, दैनिक जानकारी और सुझावों के साथ।";
"terms_myplan_description" = "आपके स्वास्थ्य इनपुट के आधार पर आहार और व्यायाम के लिए व्यक्तिगत दैनिक सिफारिशें।";
"terms_tritrack_description" = "एक \"मैं और बेबी\" दृश्य, आकार तुलना और सप्ताह-दर-सप्ताह सारांश के साथ गर्भावस्था के आपके चरण को उजागर करता है।";
"terms_mood_description" = "आपकी भावनात्मक स्थिति के अनुरूप धुनों के साथ एक मूड-आधारित ऑडियो अनुभव।";
"terms_third_party_title" = "तृतीय-पक्ष सेवाएं और ढांचे";
"terms_third_party_intro" = "एक व्यक्तिगत और सुविधा-समृद्ध अनुभव प्रदान करने के लिए, MomCare कई तृतीय-पक्ष सेवाओं, ढांचों और API के साथ एकीकृत होता है। ये सेवाएं ऐप की कार्यक्षमता को सक्षम करने के लिए कुछ प्रकार के डेटा को संभाल या संसाधित कर सकती हैं।";
