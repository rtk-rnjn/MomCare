"terms_responsibilities_title" = "उपयोगकर्ता की जिम्मेदारियाँ";
"terms_responsibilities_content" = "आप सहमत हैं कि ऐप का किसी भी गैरकानूनी तरीके से उपयोग नहीं करेंगे, इसकी कार्यक्षमताओं के साथ छेड़छाड़ नहीं करेंगे, या भ्रामक स्वास्थ्य डेटा सबमिट नहीं करेंगे।";
"terms_license_title" = "लाइसेंस और बौद्धिक संपदा";
"terms_license_content" = "MomCare और सभी संबंधित सामग्री, सुविधाएं और ब्रांडिंग MomCare की विशेष बौद्धिक संपदा हैं और कानून द्वारा संरक्षित हैं। आपको केवल व्यक्तिगत, गैर-व्यावसायिक उपयोग के लिए सीमित, गैर-अनन्य लाइसेंस दिया जाता है। आप ऐप के किसी भी हिस्से को कॉपी, संशोधित, वितरित या रिवर्स इंजीनियर नहीं कर सकते।";
"terms_data_consent_title" = "डेटा सहमति और गोपनीयता";
"terms_data_consent_content" = "हमारी सेवाओं का उपयोग करके, आप MomCare को हमारी गोपनीयता नीति के अनुसार आपके डेटा को एकत्र, संग्रहीत और संसाधित करने का अधिकार देते हैं। हम सेवाओं को बेहतर बनाने के लिए अज्ञात और एकत्रित डेटा का उपयोग करते हैं और कभी भी आपके व्यक्तिगत डेटा को नहीं बेचते।";
"terms_subscriptions_title" = "सदस्यता";
"terms_subscriptions_content" = "कुछ उन्नत सुविधाओं के लिए सदस्यता आवश्यक हो सकती है। भुगतान App Store के माध्यम से संसाधित किए जाते हैं, और आप अपनी खाता सेटिंग में अपनी सदस्यता प्रबंधित या रद्द कर सकते हैं।";
"terms_liability_title" = "दायित्व की सीमा";
"terms_liability_content" = "MomCare ऐप को \"जैसा है\" बिना किसी वारंटी के प्रदान करता है। हम ऐप के आपके उपयोग से होने वाले अप्रत्यक्ष नुकसान के लिए उत्तरदायी नहीं हैं और यह गारंटी नहीं देते कि यह त्रुटि-मुक्त होगा।";
